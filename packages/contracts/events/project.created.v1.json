{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openkate.dev/events/project.created.v1.json",
  "title": "project.created.v1",
  "type": "object",
  "required": ["eventId", "eventType", "projectId", "occurredAt", "payload"],
  "properties": {
    "eventId": {"type": "string"},
    "eventType": {"const": "project.created.v1"},
    "projectId": {"type": "string"},
    "occurredAt": {"type": "string", "format": "date-time"},
    "payload": {
      "type": "object",
      "required": ["name", "workspaceId"],
      "properties": {
        "name": {"type": "string"},
        "workspaceId": {"type": "string"}
      }
    }
  }
}

